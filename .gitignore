# ============================================================================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ============================================================================
